@using SilentOrbit.StaticOnline.Building
@using SilentOrbit.StaticOnline.Config
@inject SiteBuilder Builder
@inject SiteConfig Config
@inject PageData Page
@code {

    SiteBuilder builder => Builder ?? Config.SiteBuilder;
    SiteConfig config => Config ?? Builder.Config;

    string GetBaseHref()
    {
        var path = config.BaseURL.Href;
        Debug.Assert(path != "");
        if (path == "/")
            return "/";
        Debug.Assert(path.StartsWith('/'));
        return path + "/";
    }
}
<base href="@GetBaseHref()" />
@if (config.Favicon != null)
{
    @nl
    <link rel="icon" type="@config.Favicon.MimeType" href="@config.Favicon.URL" />
}
@{
    var robotsContent = Page.Robots.GetContent(config);
}
@if (robotsContent != null)
{
    @nl
    <meta name="robots" content="@robotsContent" />
}
@foreach (var feed in builder.Feed)
{
    @nl
    @FeedLink(feed)
}
@if (Page.Redirect != null)
{
    @nl
    <meta http-equiv="refresh" content="0; url=@Page.Redirect">
}
@{
    //Enables https://indielogin.com/
    var indieloginUrl = Page.Author?.IndieLogin ?? Config.Author.IndieLogin;
}
@if (indieloginUrl != null)
{
    @nl
    <link href="@indieloginUrl" rel="me">
}
