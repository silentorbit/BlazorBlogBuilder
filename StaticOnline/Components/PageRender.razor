@code {
    [EditorRequired]
    [Parameter]
    public PageData Page { get; set; }

    [Parameter]
    public bool? Markdown { get; set; }
}
@{
    //Optimize to not render markdown until final render
    var useMarkdown =
        (Page.BuildStage == BuildStage.FinalBuild) &&
        (Markdown ?? Page.Markdown ?? SiteBuilder.Instance.Config.Markdown.BlogPost);
}
@if (useMarkdown)
{
    <Markdown>
        <DynamicComponent Type="Page.BlazorType" />
    </Markdown>
}
else
{
    <DynamicComponent Type="Page.BlazorType" />
}
