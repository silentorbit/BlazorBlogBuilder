@code {
    [EditorRequired]
    [Parameter]
    public PageData Page { get; set; }

    [Parameter]
    public bool? Markdown { get; set; }

    public const string CascadingPageName = "Post";

    /// <summary>
    /// Detect recursion.
    /// </summary>
    [CascadingParameter(Name = CascadingPageName)]
    public PageData? PageRecursion { get; set; }
}
@{
    //Prevent recursion
    if (PageRecursion != null)
        return;
    if (Page.IsUpdate)
        throw new NotImplementedException($"{nameof(Page)}.{nameof(Page.IsUpdate)} == true, Updates should not be rendered, use their {nameof(Page.Summary)}");
    if (Page.BlazorType == null)
        throw new ArgumentException($"{nameof(Page)}.{nameof(Page.BlazorType)} is null.");

    //Optimize to not render markdown until final render
    var useMarkdown = Components.Markdown.UseMarkdown(Markdown, Page);

}
<CascadingValue Name="@CascadingPageName" Value="Page">
    <PageRenderCapture Page="Page">
        @if (useMarkdown)
        {
            <Markdown>
                <DynamicComponent Type="Page.BlazorType" />
            </Markdown>
        }
        else
        {
            <DynamicComponent Type="Page.BlazorType" />
        }
    </PageRenderCapture>
</CascadingValue>