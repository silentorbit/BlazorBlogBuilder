<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<RootNamespace>SilentOrbit.BlazorBlogBuilder</RootNamespace>
		<IsPackable>true</IsPackable>
		<PackageId>SilentOrbit.BlazorBlogBuilder</PackageId>
		<Version>0.1.1.2</Version>
		<Title>Static blog generation from Blazor</Title>
		<Authors>SilentOrbit</Authors>
		<PackageProjectUrl>https://github.com/silentorbit/BlazorBlogBuilder</PackageProjectUrl>
		<RepositoryUrl>https://github.com/silentorbit/BlazorBlogBuilder.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageTags>static-site-generator;blog-engine</PackageTags>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
	</PropertyGroup>

	<ItemGroup>
	  <None Include="..\README.md">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Markdig" Version="0.41.3" />
		<PackageReference Include="SilentOrbit.SilentDisk" Version="0.9.0" />
		<PackageReference Include="SixLabors.ImageSharp" Version="3.1.11" />
	</ItemGroup>

</Project>
